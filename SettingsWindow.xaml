<Window x:Class="RemotePlayLauncher.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Coop Launcher — Donor Setup"
        Width="620" Height="640"
        Icon="pack://application:,,,/icon.ico"
        WindowStartupLocation="CenterOwner"
        Background="#121118"
        WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Matching purple theme -->
        <SolidColorBrush x:Key="AccentBrush" Color="#5F5980"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#EBEBEB"/>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#5F5980"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#7A74A0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="#2D2B3D"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1D2B"/>
            <Setter Property="Foreground" Value="#EBEBEB"/>
            <Setter Property="CaretBrush" Value="#5F5980"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A283D"/>
            <Setter Property="Padding" Value="38,11"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="Border" Background="{TemplateBinding Background}" 
                                CornerRadius="10" BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#5F5980"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GameItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#252433"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#323045"/>
                                <Setter Property="Foreground" Value="#EBEBEB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Configure Donor Game"
                       FontSize="20" FontWeight="SemiBold" Foreground="#EBEBEB"/>
            <TextBlock FontSize="13" Foreground="#908CA0" TextWrapping="Wrap" Margin="0,6,0,0"
                       Text="Pick the Steam game that Coop Launcher replaces. Steam uses this game to enable Remote Play Together."/>
        </StackPanel>

        <!-- Search -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}" TextChanged="SearchBox_TextChanged"/>
            <StackPanel Orientation="Horizontal" IsHitTestVisible="False" Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="⌕" FontSize="16" Foreground="#5F5980" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="SearchHint" Text="Search games..." Foreground="#7A74A0" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Selection list -->
        <Border Grid.Row="2" Background="#1A1826" CornerRadius="14" Padding="4">
            <ListBox x:Name="DonorList" 
                     Background="Transparent" BorderThickness="0"
                     ItemContainerStyle="{StaticResource GameItem}"
                     SelectionChanged="DonorList_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4">
                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                            <TextBlock Text="{Binding GameFolder}" FontSize="11" Foreground="#7A74A0" Margin="0,3,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Bottom details & action -->
        <StackPanel Grid.Row="3" Margin="0,20,0,0">
            <Border Background="#1E1D2B" CornerRadius="12" Padding="16" BorderBrush="#2D2B3D" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Current Config" FontSize="11" FontWeight="Bold" Foreground="#5F5980" Margin="0,0,0,4"/>
                        <TextBlock x:Name="CurrentDonorName" Text="None" Foreground="#EBEBEB" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CurrentDonorPath" Text="Please select a game above..." FontSize="11" Foreground="#908CA0" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="InstallBtn" Content="Install Launcher Here" 
                            Style="{StaticResource ActionBtn}" IsEnabled="False" VerticalAlignment="Center"
                            Click="InstallBtn_Click"/>
                </Grid>
            </Border>
            <TextBlock x:Name="ActionStatus" Text="" Foreground="#7A74A0" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
