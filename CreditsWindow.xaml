<Window x:Class="RemotePlayLauncher.CreditsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Coop Launcher Credits"
        Width="420" Height="480"
        Icon="pack://application:,,,/icon.ico"
        WindowStartupLocation="CenterOwner"
        Background="#121118"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#5F5980"/>
        <Style x:Key="HyperlinkBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7A74A0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" 
                                   TextDecorations="Underline"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            
            <TextBlock Text="Coop Launcher" Foreground="#EBEBEB" FontSize="26" 
                       FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="v1.0.0 — Stable" Foreground="#5F5980" FontSize="14" 
                       HorizontalAlignment="Center" Margin="0,8,0,40"/>

            <TextBlock Text="Developed with 💜 by" Foreground="#908CA0" 
                       FontSize="13" HorizontalAlignment="Center"/>
            <TextBlock Text="Matheus Baliver" Foreground="#FFFFFF" 
                       FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,14"/>
            
            <Button Content="github.com/MBaliver" Style="{StaticResource HyperlinkBtn}"
                    FontSize="15" HorizontalAlignment="Center" Click="Github_Click"/>

            <Border Height="1" Background="#222030" Margin="0,50,0,40" Width="180"/>

            <TextBlock Text="Thank you for using Coop Launcher!" Foreground="#908CA0" 
                       FontSize="13" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
            
        </StackPanel>
    </Grid>
</Window>
